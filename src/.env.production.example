# Backend Environment Variables for Render

# Database Connection
ConnectionStrings__PostgresConnection=postgresql://user:password@neon-host.neon.tech/databank_refactored?sslmode=require

# JWT Configuration
Jwt__Issuer=https://your-backend.onrender.com
Jwt__Audience=https://your-frontend.vercel.app
Jwt__SigningKey=GENERATE_A_SECURE_KEY_AT_LEAST_32_CHARACTERS_LONG

# Frontend URL for CORS
FRONTEND_URL=https://your-frontend.vercel.app

# ASP.NET Core Configuration
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:10000

# Logging
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft__AspNetCore=Warning
